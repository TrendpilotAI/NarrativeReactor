# NarrativeReactor Environment Variables

# Server
NR_PORT=3401
GENKIT_PORT=3402
API_KEY=your-api-key-here

# CORS — comma-separated list of allowed origins (required in production)
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://dashboard.example.com

# Token encryption key — 64-char hex string (32 bytes). Required in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOKEN_ENCRYPTION_KEY=

# LinkedIn OAuth2 — required for NR-006 native publishing authorization
# Create an app at https://www.linkedin.com/developers/apps
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Dashboard authentication
# DASHBOARD_PASSWORD — required in production. Without it, dashboard is inaccessible.
# DASHBOARD_PASSWORD=your-dashboard-password
# JWT_SECRET — optional. Falls back to API_KEY if not set.
# JWT_SECRET=

# AI Providers
GOOGLE_GENAI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-claude-key
FAL_KEY=your-fal-ai-key

# fal.ai Model Overrides (optional)
# FAL_IMAGE_MODEL=fal-ai/hunyuan-image/v3/instruct/text-to-image
# FAL_VIDEO_MODEL=fal-ai/bytedance/seedance/v1.5/pro/text-to-video

# Stripe Billing — required for paid plans and metered billing (NR-002)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...

# Webhook Security
WEBHOOK_SECRET=your-webhook-secret

# Error Reporting (Sentry)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Cost Overrides (optional, USD per call)
# COST_FAL_IMAGE=0.01
# COST_FAL_VIDEO=0.10
# COST_CLAUDE_CALL=0.03
