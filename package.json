{
  "name": "narrative-reactor",
  "version": "1.0.0",
  "description": "AI-powered content generation platform for Signal Studio",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "genkit start -- npx tsx --watch src/index.ts",
    "docs:serve": "mkdocs serve",
    "docs:build": "mkdocs build",
    "docs:deploy": "mkdocs gh-deploy --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=junit --outputFile=test-results.xml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.0",
    "@fal-ai/client": "^1.8.4",
    "@genkit-ai/dotprompt": "^0.9.12",
    "@genkit-ai/express": "^1.27.0",
    "@genkit-ai/firebase": "^1.29.0",
    "@genkit-ai/google-genai": "^1.29.0",
    "@genkit-ai/vertexai": "^1.29.0",
    "@types/cors": "^2.8.19",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^3.0.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^12.0.0",
    "genkit": "^1.29.0",
    "genkitx-anthropic": "^0.30.0",
    "helmet": "^8.1.0",
    "lodash": "^4.17.21",
    "mime-types": "^3.0.2",
    "stripe": "^20.4.1",
    "twitter-api-v2": "^1.29.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "firebase-tools": "^15.3.0",
    "genkit-cli": "^1.29.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
