{
  "name": "narrative-reactor",
  "version": "1.0.0",
  "description": "AI-powered content generation platform for Signal Studio",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "genkit start -- npx tsx --watch src/index.ts",
    "docs:serve": "mkdocs serve",
    "docs:build": "mkdocs build",
    "docs:deploy": "mkdocs gh-deploy --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=junit --outputFile=test-results.xml",
    "prepare": "husky",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "postinstall": "sed -i 's/\\[key: string\\]: string | string\\[\\];/[key: string]: string;/' node_modules/@types/express-serve-static-core/index.d.ts 2>/dev/null || true"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@fal-ai/client": "^1.8.4",
    "@genkit-ai/dotprompt": "^0.9.12",
    "@genkit-ai/express": "^1.27.0",
    "@genkit-ai/google-genai": "^1.29.0",
    "@genkit-ai/vertexai": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^3.0.1",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "genkit": "^1.29.0",
    "genkitx-anthropic": "^0.30.0",
    "helmet": "^8.1.0",
    "lodash": "^4.17.21",
    "mime-types": "^3.0.2",
    "stripe": "^20.4.1",
    "twitter-api-v2": "^1.29.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.0.0",
    "firebase-tools": "^15.3.0",
    "genkit-cli": "^1.29.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
